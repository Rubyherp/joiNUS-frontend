{
  "name": "joinus-frontend",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest"
  },
  "dependencies": {
    "@expo/html-elements": "^0.12.5",
    "@expo/vector-icons": "^15.0.3",
    "@gluestack-ui/core": "^3.0.20",
    "@gluestack-ui/linear-gradient": "^0.1.3",
    "@gluestack-ui/nativewind-utils": "^1.0.28",
    "@gluestack-ui/utils": "^3.0.21",
    "@legendapp/motion": "^2.5.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@types/react": "~19.1.10",
    "@types/react-native": "^0.72.8",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-device": "~8.0.10",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-network": "~8.0.8",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "lucide-react-native": "^1.17.0",
    "nativewind": "^4.2.4",
    "react": "19.1.0",
    "react-aria": "^3.48.0",
    "react-dom": "^19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.5",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "react-stately": "^3.46.0",
    "tailwind-variants": "^0.1.20",
    "typescript": "~5.9.2"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "testEnvironment": "node",
    "transformIgnorePatterns": [
      "node_modules/(?!(@gluestack-ui|nativewind|react-native|@react-native|@expo|expo|expo-linear-gradient|expo-modules-core|expo-constants|expo-asset|expo-file-system|expo-font|expo-image-picker|react-native-css-interop|react-native-reanimated)/)"
    ],
    "moduleNameMapper": {
      "\\.(png|jpg|jpeg|gif|webp)$": "<rootDir>/test/__mocks__/fileMock.js",
      "^@/components/ui/linear-gradient$": "<rootDir>/test/__mocks__/linearGradient.js",
      "^nativewind$": "<rootDir>/test/__mocks__/nativewind.js",
      "^expo-image-picker$": "<rootDir>/test/__mocks__/imagePicker.js"
    }
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@testing-library/react-native": "^13.2.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "jest": "^29.7.0",
    "jest-expo": "^54.0.6",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "react-test-renderer": "19.1.0",
    "tailwindcss": "^3.4.19"
  }
}
